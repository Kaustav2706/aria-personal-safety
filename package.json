{
  "name": "aria-monorepo",
  "version": "1.0.0",
  "description": "ARIA (AI Real-time Incident Assistant) Safety Platform Monorepo",
  "private": true,
  "scripts": {
    "dev": "vite",
    "install:all": "npm run install:backend && npm run install:dashboard && npm run install:mobile",
    "install:backend": "cd backend && npm install",
    "install:dashboard": "cd police-dashboard && npm install",
    "install:mobile": "cd mobile && npm install",
    "start:backend": "cd backend && npm start",
    "start:dashboard": "cd police-dashboard && npm run dev",
    "start:mobile": "cd mobile && npm run start"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "twilio": "^6.0.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "keywords": [
    "monorepo",
    "safety",
    "express",
    "react",
    "expo",
    "fastapi"
  ],
  "author": "ARIA Safety Team"
}
