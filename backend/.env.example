# ARIA Server Configuration
PORT=5000
JWT_SECRET=aria_secure_jwt_secret_key_change_me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aria

# Twilio (SMS Alerts)
TWILIO_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=aria-safety-app
FIREBASE_PRIVATE_KEY_BASE64=base64_encoded_private_key_string
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@aria-safety-app.iam.gserviceaccount.com
