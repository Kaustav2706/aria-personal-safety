# ARIA Server Configuration
PORT=5000
JWT_SECRET=aria_secure_jwt_secret_key_change_me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aria

# Twilio (SMS Alerts)
TWILIO_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY_BASE64=your-base64-encoded-private-key-string
FIREBASE_PRIVATE_KEY="your-raw-pem-private-key-fallback"

# Police Dashboard API Key
POLICE_API_KEY=your-police-dashboard-api-key
